# parcel_write_safety.rules
# Technology: parcel | Capability: write

rule parcel-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_parcel_PATTERN"
  MESSAGE "Blocked an unsafe pattern in parcel. Use the recommended best practices for 2025/2026."
}

rule parcel-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_parcel_API"
  MESSAGE "You are using an outdated API for parcel. Please upgrade to the newer API."
}
